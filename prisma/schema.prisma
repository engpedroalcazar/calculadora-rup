generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id            String   @id @default(cuid())
  nome          String
  whatsapp      String
  email         String?
  perfil        String?
  tipoObra      String?
  preocupacao   String?
  controle      String?
  cidade        String?

  atividadeId   String
  atividadeNome String
  unidade       String
  quantidade    Float
  trabalhadores Int
  horasPorDia   Float
  dias          Int
  custoHora     Float?

  hhTotal       Float
  rupReal       Float
  rupRef        Float
  desvio        Float
  severidade    String

  pago             Boolean  @default(false)
  valor            Float?
  metodoPagamento  String?   // "pix" | "credit_card" | "debit_card" | "ticket" | "manual"

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([severidade])
  @@index([pago])
  @@index([createdAt])
}

model Pacote {
  id        String   @id @default(cuid())
  email     String                        // dono do pacote — matching por email
  total     Int      @default(10)         // créditos totais (10 análises)
  usado     Int      @default(1)          // 1 já gasto no lead que gerou a compra
  ativo     Boolean  @default(true)
  leadId    String?                       // lead que originou a compra
  expiraEm  DateTime                      // 30 dias da compra
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email, ativo])
  @@index([expiraEm])
}

// =====================================================================
// Models do Produto #2 — Calculadora de Orçamento
// Adicionados em 2026-05-29 na unificação ORC → RUP (Caminho B).
// Models acima (Lead, Pacote) permanecem intocados.
// =====================================================================

model OrcamentoLead {
  id                 String   @id @default(cuid())
  nome               String
  email              String
  whatsapp           String?
  empresa            String?
  perfil             String?

  uf                 String
  cidade             String?

  // Campos legados (Iter #1-#3 — orçamento single-item). A partir da Iter #4 a fonte
  // de verdade dos serviços é `itens[]`. Mantidos nullable pra preservar leads antigos.
  atividadeId        String?
  atividadeNome     String?
  unidade            String?
  quantidade         Float?
  padraoAcabamento   String?

  bdiPercentual      Float

  // Totais agregados — soma dos itens (ou valor único, se lead legado single-item).
  custoMaterialTotal Float
  custoMaoObra       Float
  custoDireto        Float
  custoFinal         Float
  custoPorUnidade    Float
  hhTotal            Float
  prazoDias          Int
  equipeSugerida     Int

  // Snapshot da lista de insumos CONSOLIDADA (todos os itens somados por código),
  // calculada no momento do orçamento. Preserva o resultado mesmo se Insumo mudar depois.
  insumosCalculadosJson String?

  // Itens do orçamento (1-N). Vazio em leads legados single-item.
  itens              OrcamentoItem[]

  pago               Boolean  @default(false)
  valor              Float?
  metodoPagamento    String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([email])
  @@index([pago])
  @@index([createdAt])
}

model OrcamentoItem {
  id                    String   @id @default(cuid())
  leadId                String
  lead                  OrcamentoLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  atividadeId           String
  atividadeNome         String
  unidade               String
  categoriaProfissional String   // snapshot — usado pra agregar MO consolidada

  quantidade            Float
  padraoAcabamento      String   // per-item — cada serviço pode ter padrão próprio

  custoMaterialTotal    Float
  custoMaoObra          Float
  custoDireto           Float
  hhTotal               Float
  prazoDias             Int

  insumosCalculadosJson String?

  // "manual" = cliente adicionou direto; "sugerido" = veio de combo aceito
  origem                String   @default("manual")
  comboTriggerId        String?  // se origem=sugerido, qual atividade gatilho

  createdAt             DateTime @default(now())

  @@index([leadId])
  @@index([atividadeId])
}

model OrcamentoPacote {
  id        String   @id @default(cuid())
  email     String
  total     Int      @default(10)
  usado     Int      @default(1)
  ativo     Boolean  @default(true)
  leadId    String?
  expiraEm  DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([ativo])
}

model Insumo {
  id                 String   @id @default(cuid())
  codigo             String   @unique
  descricao          String
  unidade            String
  custoUnitarioMedio Float
  codigoSinapi       String?
  fonte              String

  atividadeInsumos   AtividadeInsumo[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([codigo])
}

model AtividadeInsumo {
  id              String   @id @default(cuid())
  atividadeId     String
  insumoId        String
  insumo          Insumo   @relation(fields: [insumoId], references: [id], onDelete: Cascade)

  qtdePorUnidade  Float
  fatorPerda      Float    @default(1.0)
  observacao      String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([atividadeId, insumoId])
  @@index([atividadeId])
}
