generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id            String   @id @default(cuid())
  nome          String
  whatsapp      String
  email         String?
  perfil        String?
  tipoObra      String?
  preocupacao   String?
  controle      String?
  cidade        String?

  atividadeId   String
  atividadeNome String
  unidade       String
  quantidade    Float
  trabalhadores Int
  horasPorDia   Float
  dias          Int
  custoHora     Float?

  hhTotal       Float
  rupReal       Float
  rupRef        Float
  desvio        Float
  severidade    String

  pago             Boolean  @default(false)
  valor            Float?
  metodoPagamento  String?   // "pix" | "credit_card" | "debit_card" | "ticket" | "manual"

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([severidade])
  @@index([pago])
  @@index([createdAt])
}
